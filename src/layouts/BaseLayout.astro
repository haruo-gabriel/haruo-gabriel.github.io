---
interface Props {
	title: string;
}

const { title } = Astro.props;

import { ClientRouter } from 'astro:transitions';
import "../styles/styles.css";
import "../styles/header.css";
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<header class="header">
			<a href="/">haruo g.</a>
		</header>

		<main class="main-content">
			<slot />
		</main>
	</body>
</html>
