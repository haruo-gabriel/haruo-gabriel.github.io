---
import type { Tag } from "../data/tags";

interface Props {
	tags: Tag[];
}

const { tags } = Astro.props;

// Categorized order from general to specific
const categoryOrder: Record<string, number> = {
	domain: 1,
	tool: 2,
	project: 3,
	language: 4,
};

// Sort tags by category, and secondarily alphabetically by label
const sortedTags = [...tags].sort((a, b) => {
	const orderA = categoryOrder[a.category] ?? 99;
	const orderB = categoryOrder[b.category] ?? 99;
	
	if (orderA !== orderB) {
		return orderA - orderB;
	}
	return a.label.localeCompare(b.label);
});
---

<div class="tag-container">
	{
		sortedTags.map((tag) => (
			<span class={`tag ${tag.cssClass}`} data-category={tag.category}>
				{tag.label}
			</span>
		))
	}
</div>

<style>
	.tag-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.tag {
		color: var(--text-color);
		font-family: var(--font-family-secondary);
		font-size: 0.85rem;
		padding: 0.3rem 0.8rem;
		border-radius: 8px;

		/* Glassmorphism effect */
		background: rgba(20, 20, 20, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.1);
		box-shadow:
			0 8px 32px rgba(0, 0, 0, 0.3),
			inset 0 1px 0 rgba(255, 255, 255, 0.5),
			inset 0 -1px 0 rgba(255, 255, 255, 0.1),
			inset 0 0 22px 11px rgba(255, 255, 255, 0.05);
	}

	.tag[data-category="language"] {
		border-color: rgba(74, 222, 128, 0.25);
		color: rgba(74, 222, 128, 0.95);
	}

	.tag[data-category="tool"] {
		border-color: rgba(251, 191, 36, 0.25);
		color: rgba(251, 191, 36, 0.95);
	}

	.tag[data-category="domain"] {
		border-color: rgba(244, 63, 94, 0.25);
		color: rgba(244, 63, 94, 0.95);
	}

	.tag[data-category="project"] {
		border-color: rgba(96, 165, 250, 0.25);
		color: rgba(96, 165, 250, 0.95);
	}
</style>
