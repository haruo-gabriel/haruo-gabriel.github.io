	.social-link:hover .icon {
		background-image: linear-gradient(
			135deg,
			#ffffff 0%,
			#888888 25%,
			#e0e0e0 50%,
			#444444 75%,
			#ffffff 100%
		);
		background-size: 200% auto;
		background-position: right center;
		background-color: transparent;
		filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.5));
		transform: scale(1.1);
	}
</style>
