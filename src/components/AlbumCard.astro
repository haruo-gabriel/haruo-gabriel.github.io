---
import { Image } from "astro:assets";
import PlayerButton from "./PlayerButton.astro";

interface Props {
	title: string;
	artist: string;
	cover: ImageMetadata;
	year: number;
	soundcloudUrl: string;
}

const { title, artist, cover, year, soundcloudUrl } = Astro.props;
---

<article class="album-card" data-soundcloud-url={soundcloudUrl}>
	<!-- ─── HEADER (clickable toggle) ──────────────────────── -->
	<div class="card-header">
		<div class="cover-wrapper">
			<Image
				src={cover}
				alt={`Capa do álbum ${title}`}
				class="cover-image"
				width={600}
				height={600}
				format="webp"
				loading="eager"
			/>
		</div>

		<div class="content-wrapper">
			<div class="title-header">
				<h2 class="album-title">{title}</h2>
				<span class="album-year">{year}</span>
				<!-- Glowing dot — visible only while audio is playing -->
				<span class="now-playing-dot" aria-hidden="true"></span>
			</div>
			<span class="album-artist">{artist}</span>
		</div>
	</div>

	<!-- ─── EXPAND PANEL (collapsed by default) ───────────── -->
	<div class="card-expand-panel">
		<!-- Hidden audio engine — persists independently -->
		<div class="iframe-container" aria-hidden="true"></div>

		<!-- Loading spinner (shown while Widget initialises) -->
		<div class="loader-container">
			<div class="spinner"></div>
		</div>

		<!-- Custom player UI (revealed after Widget READY) -->
		<div class="custom-player" aria-label="Player de música" role="region">
			<div class="player-now-playing">
				<span class="player-track-title">—</span>
				<span class="player-track-artist"></span>
			</div>

			<div class="player-progress-wrap">
				<div
					class="player-progress-bar"
					role="slider"
					tabindex="0"
					aria-label="Progresso da faixa"
					aria-valuemin="0"
					aria-valuemax="100"
					aria-valuenow="0"
				>
					<div class="player-load-fill"></div>
					<div class="player-progress-fill"></div>
					<div class="player-thumb"></div>
				</div>
				<div class="player-time">
					<span class="player-time-current">0:00</span>
					<span class="player-time-total">0:00</span>
				</div>
			</div>

			<div class="player-controls">
				<PlayerButton type="prev" ariaLabel="Faixa anterior" />
				<PlayerButton type="playpause" ariaLabel="Reproduzir" />
				<PlayerButton type="next" ariaLabel="Próxima faixa" />
			</div>

			<ol class="player-tracklist" aria-label="Lista de faixas"></ol>

			<!-- SoundCloud attribution (Terms of Use requirement) -->
			<a
				class="sc-attribution"
				href={soundcloudUrl}
				target="_blank"
				rel="noopener noreferrer"
				aria-label={`Ouça ${title} no SoundCloud`}
			>
				<span class="sc-mark" aria-hidden="true">
					<svg
						role="img"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
						><title>SoundCloud</title><path
							d="M23.999 14.165c-.052 1.796-1.612 3.169-3.4 3.169h-8.18a.68.68 0 0 1-.675-.683V7.862a.747.747 0 0 1 .452-.724s.75-.513 2.333-.513a5.364 5.364 0 0 1 2.763.755 5.433 5.433 0 0 1 2.57 3.54c.282-.08.574-.121.868-.12.884 0 1.73.358 2.347.992s.948 1.49.922 2.373ZM10.721 8.421c.247 2.98.427 5.697 0 8.672a.264.264 0 0 1-.53 0c-.395-2.946-.22-5.718 0-8.672a.264.264 0 0 1 .53 0ZM9.072 9.448c.285 2.659.37 4.986-.006 7.655a.277.277 0 0 1-.55 0c-.331-2.63-.256-5.02 0-7.655a.277.277 0 0 1 .556 0Zm-1.663-.257c.27 2.726.39 5.171 0 7.904a.266.266 0 0 1-.532 0c-.38-2.69-.257-5.21 0-7.904a.266.266 0 0 1 .532 0Zm-1.647.77a26.108 26.108 0 0 1-.008 7.147.272.272 0 0 1-.542 0 27.955 27.955 0 0 1 0-7.147.275.275 0 0 1 .55 0Zm-1.67 1.769c.421 1.865.228 3.5-.029 5.388a.257.257 0 0 1-.514 0c-.21-1.858-.398-3.549 0-5.389a.272.272 0 0 1 .543 0Zm-1.655-.273c.388 1.897.26 3.508-.01 5.412-.026.28-.514.283-.54 0-.244-1.878-.347-3.54-.01-5.412a.283.283 0 0 1 .56 0Zm-1.668.911c.4 1.268.257 2.292-.026 3.572a.257.257 0 0 1-.514 0c-.241-1.262-.354-2.312-.023-3.572a.283.283 0 0 1 .563 0Z"
						></path></svg
					>
				</span>
				<span>Ouça no SoundCloud</span>
			</a>
		</div>
	</div>

	<style>
		/* ── Card shell ─────────────────────────────────────────────── */
		.album-card {
			position: relative;
			width: 100%;
			max-width: 400px;
			margin: 2rem auto;
			border-radius: 20px;
			padding: 2rem;
			background: rgba(20, 20, 20, 0.6);
			backdrop-filter: blur(15px);
			-webkit-backdrop-filter: blur(15px);
			border: 1px solid rgba(255, 255, 255, 0.1);
			box-shadow:
				0 8px 32px rgba(0, 0, 0, 0.3),
				inset 0 1px 0 rgba(255, 255, 255, 0.5),
				inset 0 -1px 0 rgba(255, 255, 255, 0.1),
				inset 0 0 22px 11px rgba(255, 255, 255, 0.05);
			transition:
				transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
				box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
				border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
			-webkit-tap-highlight-color: transparent;
		}

		/* Hover lift (only when not expanded) */
		.album-card:hover:not(.active) {
			transform: translateY(-6px);
			box-shadow:
				0 16px 48px rgba(0, 0, 0, 0.45),
				inset 0 1px 0 rgba(255, 255, 255, 0.65),
				inset 0 -1px 0 rgba(255, 255, 255, 0.15),
				inset 0 0 22px 11px rgba(255, 255, 255, 0.08);
			border-color: rgba(255, 255, 255, 0.15);
		}

		/* Metallic shine – top edge */
		.album-card::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 1px;
			background: linear-gradient(
				90deg,
				transparent,
				rgba(255, 255, 255, 0.8),
				transparent
			);
			pointer-events: none;
			z-index: 3;
			border-radius: 20px 20px 0 0;
		}

		/* ── Card header (clickable toggle) ────────────────────────── */
		.card-header {
			cursor: pointer;
			display: flex;
			flex-direction: column;
			user-select: none;
		}

		.album-card.active .card-header {
			cursor: pointer;
		}

		.cover-wrapper {
			width: 100%;
			aspect-ratio: 1 / 1;
			border-radius: 16px;
			overflow: hidden;
			margin-bottom: 2rem;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
		}

		.cover-image {
			width: 100%;
			height: 100%;
			aspect-ratio: 1 / 1;
			object-fit: cover;
			transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
		}

		.content-wrapper {
			display: flex;
			flex-direction: column;
			flex-grow: 1;
		}

		.title-header {
			display: flex;
			align-items: center;
			gap: 0.75rem;
		}

		h2.album-title {
			font-family: var(--font-family-main);
			font-size: var(--text-xl);
			color: var(--heading-color);
			margin: 0;
		}

		.album-year {
			font-family: var(--font-family-secondary);
			font-size: var(--text-lg);
			color: var(--text-color-muted);
			font-style: italic;
			flex-shrink: 0;
		}

		.album-artist {
			font-family: var(--font-family-secondary);
			font-size: var(--text-base);
			color: var(--text-color-muted);
			font-style: italic;
			margin: 0;
			text-align: left;
		}

		/* ── Now-playing dot ────────────────────────────────────────── */
		.now-playing-dot {
			width: 8px;
			height: 8px;
			border-radius: 50%;
			background: #fff;
			flex-shrink: 0;
			opacity: 0;
			box-shadow: 0 0 6px 2px rgba(255, 255, 255, 0.5);
			transition: opacity 0.4s ease;
			margin-left: 0.5rem;
		}

		.album-card.playing .now-playing-dot {
			opacity: 1;
			animation: dot-glow 8s ease-in-out infinite;
		}

		@keyframes dot-glow {
			0%,
			100% {
				box-shadow: 0 0 4px 1px rgba(255, 255, 255, 0.4);
			}
			50% {
				box-shadow: 0 0 10px 4px rgba(255, 255, 255, 0.5);
			}
		}

		/* ── Expand panel ──────────────────────────────────────────── */
		.card-expand-panel {
			max-height: 0;
			opacity: 0;
			overflow: hidden;
			transition:
				max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
				opacity 0.4s ease;
			position: relative;
		}

		.album-card.active .card-expand-panel {
			max-height: 800px;
			opacity: 1;
		}

		/* Hidden audio engine: absolutely positioned, visually hidden but active */
		.iframe-container {
			position: absolute;
			top: 0;
			left: 0;
			width: 10px;
			height: 10px;
			opacity: 0;
			pointer-events: none;
			overflow: hidden;
			z-index: -10;
		}

		/* ── Loader ─────────────────────────────────────────────────── */
		.loader-container {
			display: none; /* toggled by JS */
			justify-content: center;
			align-items: center;
			padding: 3rem 0;
		}

		.spinner {
			width: 36px;
			height: 36px;
			border: 3px solid rgba(255, 255, 255, 0.1);
			border-top-color: #ff5500;
			border-radius: 50%;
			animation: spin 0.8s linear infinite;
		}

		@keyframes spin {
			to {
				transform: rotate(360deg);
			}
		}

		/* ── Custom player ──────────────────────────────────────────── */
		.custom-player {
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
			flex: 1;
			min-height: 0;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.35s ease;
			padding-top: 1.5rem;
			border-top: 1px solid rgba(255, 255, 255, 0.08);
		}

		.custom-player.visible {
			opacity: 1;
			pointer-events: auto;
		}

		/* Now-playing info */
		.player-now-playing {
			display: flex;
			flex-direction: column;
			gap: 0.1rem;
		}

		.player-track-title {
			font-family: var(--font-family-secondary);
			font-size: var(--text-lg);
			color: var(--heading-color);
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.player-track-artist {
			font-family: var(--font-family-secondary);
			font-size: var(--text-sm);
			color: var(--text-color-muted);
			font-style: italic;
		}

		/* Progress */
		.player-progress-wrap {
			display: flex;
			flex-direction: column;
			gap: 0.3rem;
		}

		.player-progress-bar {
			position: relative;
			height: 4px;
			background: rgba(255, 255, 255, 0.15);
			border-radius: 4px;
			cursor: pointer;
			overflow: visible;
			transition: height 0.15s ease;
		}

		.player-progress-bar:hover {
			height: 5px;
		}

		.player-progress-bar:focus-visible {
			outline: 2px solid #ff5500;
			outline-offset: 4px;
		}

		.player-load-fill,
		.player-progress-fill {
			position: absolute;
			top: 0;
			left: 0;
			height: 100%;
			border-radius: 4px;
			width: 0%;
			pointer-events: none;
			transition: width 0.25s linear;
		}

		.player-load-fill {
			background: rgba(255, 255, 255, 0.18);
		}
		.player-progress-fill {
			background: #ff5500;
			z-index: 1;
		}

		.player-thumb {
			position: absolute;
			top: 50%;
			left: 0%;
			transform: translate(-50%, -50%);
			width: 12px;
			height: 12px;
			border-radius: 50%;
			background: #fff;
			box-shadow: 0 0 4px rgba(0, 0, 0, 0.4);
			opacity: 0;
			pointer-events: none;
			z-index: 2;
			transition: opacity 0.15s ease;
		}

		.player-progress-bar:hover .player-thumb {
			opacity: 1;
		}

		.player-time {
			display: flex;
			justify-content: space-between;
			font-family: var(--font-family-secondary);
			font-size: 1rem;
			color: var(--text-color-muted);
			font-variant-numeric: tabular-nums;
		}

		/* Transport controls */
		.player-controls {
			display: flex;
			justify-content: center;
			align-items: center;
			gap: 0.75rem;
		}

		/* Tracklist */
		.player-tracklist {
			list-style: none;
			counter-reset: track-counter;
			margin: 0;
			padding: 0;
			max-height: 200px;
			overflow-y: auto;
			overflow-x: hidden;
			display: flex;
			flex-direction: column;
			gap: 0.1rem;
			/* Hide scrollbar across browsers */
			scrollbar-width: none;
			-ms-overflow-style: none;
		}

		.player-tracklist::-webkit-scrollbar {
			display: none;
		}

		.player-tracklist :global(.player-track-item) {
			counter-increment: track-counter;
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
			padding: 0.3rem 0.5rem;
			border-radius: 6px;
			cursor: pointer;
			font-family: var(--font-family-secondary);
			font-size: var(--text-sm);
			color: var(--text-color);
			transition:
				background 0.15s ease,
				color 0.15s ease;
			user-select: none;
			margin-left: 0;
		}

		.player-tracklist :global(.player-track-item::before) {
			content: counter(track-counter) ".";
			color: var(--text-color-muted);
			font-style: italic;
			font-size: 0.9em;
			width: 1.25rem;
			flex-shrink: 0;
		}

		.player-tracklist :global(.player-track-item:hover:not(.blocked)) {
			background: rgba(255, 255, 255, 0.08);
			color: var(--heading-color);
		}

		.player-tracklist :global(.player-track-item.active) {
			background: rgba(255, 85, 0, 0.12);
			color: var(--heading-color);
			font-style: italic;
			font-weight: bold;
		}

		.player-tracklist :global(.player-track-item.blocked) {
			opacity: 0.35;
			cursor: not-allowed;
		}

		/* ── SoundCloud attribution ─────────────────────────────────── */
		.sc-attribution {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			text-decoration: none;
			font-family: var(--font-family-secondary);
			font-size: var(--text-sm);
			color: var(--text-color-muted);
			transition: color 0.2s ease;
			margin-top: auto;
			align-self: flex-start;
		}

		.sc-attribution:hover {
			color: #ff5500;
		}

		.sc-mark {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 1.4rem;
			height: 1.4rem;
			background: #ff5500;
			color: #fff;
			border-radius: 4px;
			padding: 0.25rem;
			flex-shrink: 0;
		}

		.sc-mark svg {
			width: 100%;
			height: 100%;
			fill: currentColor;
		}

		/* ── Mobile overrides ───────────────────────────────────────── */
		@media (max-width: 440px) {
			.album-card {
				padding: 1.25rem;
			}

			.cover-wrapper {
				margin-bottom: 1.25rem;
			}

			.content-wrapper {
				gap: 0rem;
			}

			h2.album-title {
				font-size: var(--text-lg);
			}

			.album-year {
				font-size: var(--text-base);
			}

			.player-tracklist :global(.player-track-item) {
				font-size: var(--text-sm);
			}
		}
	</style>

	<script>
		import "./soundcloud-player.ts";
	</script>
</article>
