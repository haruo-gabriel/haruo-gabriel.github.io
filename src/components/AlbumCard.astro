---
import { Image } from "astro:assets";
import CloseButton from "./CloseButton.astro";

interface Props {
	title: string;
	cover: ImageMetadata;
	year: number;
	tracks: string[];
	soundcloudUrl: string;
}

const { title, cover, year, tracks, soundcloudUrl } = Astro.props;
---

<article class="album-card" data-soundcloud-url={soundcloudUrl}>
	<div class="card-inner">
		<!-- Card front containing original content -->
		<div class="card-front">
			<div class="cover-wrapper">
				<Image
					src={cover}
					alt={`Capa do álbum ${title}`}
					class="cover-image"
					width={600}
					height={600}
					format="webp"
					loading="eager"
				/>
			</div>

			<div class="content-wrapper">
				<div class="title-header">
					<h2 class="album-title">{title}</h2>
					<span class="album-year">{year}</span>
				</div>

				<ol class="track-list">
					{
						tracks.map((track) => (
							<li class="track-item">
								<span class="track-name">{track}</span>
							</li>
						))
					}
				</ol>
			</div>
		</div>

		<!-- Card back containing SoundCloud player, loading spinner, and close button -->
		<div class="card-back">
			<div class="loader-container" style="display: none;">
				<div class="spinner"></div>
			</div>
			<CloseButton
				ariaLabel="Voltar para detalhes do álbum"
				size={34}
				svgSize={16}
				top="1rem"
				right="1rem"
				mobileSize={34}
				mobileTop="1rem"
				mobileRight="1rem"
				zIndex={10}
			/>
			<div class="iframe-container"></div>
		</div>
	</div>
</article>

<style>
	.album-card {
		perspective: 1500px;
		width: 100%;
		max-width: 400px;
		margin: 2rem auto;
		background: transparent;
		border: none;
		box-shadow: none;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
	}

	@media (max-width: 440px) {
		.card-front,
		.card-back {
			padding: 1.25rem;
		}
		.cover-wrapper {
			margin-bottom: 1.25rem;
		}
		.content-wrapper {
			gap: 1rem;
		}
		.album-title {
			font-size: var(--text-lg);
		}
		.album-year {
			font-size: var(--text-base);
		}
		.track-item {
			font-size: var(--text-sm);
		}
	}

	.album-card.active {
		cursor: default;
	}

	/* Card inner wrapper that performs the 3D rotation */
	/* Grid stacking: both faces share one cell, letting the wrapper grow to fit content */
	.card-inner {
		position: relative;
		width: 100%;
		display: grid;
		grid-template-areas: "face";
		transform-style: preserve-3d;
		transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.album-card.active .card-inner {
		transform: rotateY(180deg);
	}

	/* Bug 1 fix: prevent invisible front face from blocking iframe pointer events */
	.album-card.active .card-front {
		pointer-events: none;
	}

	/* Hover lift animation on the entire card structure when not active */
	.album-card:hover:not(.active) .card-inner {
		transform: translateY(-6px);
	}

	/* Front & Back Faces */
	.card-front,
	.card-back {
		grid-area: face; /* Stacks both faces in the same grid cell */
		width: 100%;
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		border-radius: 20px;
		padding: 2rem;
		overflow: hidden;

		/* Glassmorphism styling moved here */
		background: rgba(20, 20, 20, 0.6);
		backdrop-filter: blur(15px);
		-webkit-backdrop-filter: blur(15px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		box-shadow:
			0 8px 32px rgba(0, 0, 0, 0.3),
			inset 0 1px 0 rgba(255, 255, 255, 0.5),
			inset 0 -1px 0 rgba(255, 255, 255, 0.1),
			inset 0 0 22px 11px rgba(255, 255, 255, 0.05);

		transition:
			box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* Enhanced shadow on hover for inactive card front */
	.album-card:hover:not(.active) .card-front {
		box-shadow:
			0 16px 48px rgba(0, 0, 0, 0.45),
			inset 0 1px 0 rgba(255, 255, 255, 0.65),
			inset 0 -1px 0 rgba(255, 255, 255, 0.15),
			inset 0 0 22px 11px rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.15);
	}

	/* Metallic shine borders for both faces */
	.card-front::before,
	.card-back::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.8),
			transparent
		);
		pointer-events: none;
		z-index: 3;
	}

	.card-front::after,
	.card-back::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 1px;
		height: 100%;
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0.8),
			transparent,
			rgba(255, 255, 255, 0.3)
		);
		pointer-events: none;
		z-index: 3;
	}

	.card-front {
		z-index: 2;
		transform: rotateY(0deg);
		display: flex;
		flex-direction: column;
	}

	.card-back {
		z-index: 1;
		transform: rotateY(180deg);
		display: flex;
		flex-direction: column;
		padding-top: 3.5rem; /* Room for close button */
		min-height: 380px; /* Prevents iframe side from collapsing when content-less */
	}

	.cover-wrapper {
		width: 100%;
		aspect-ratio: 1 / 1;
		border-radius: 16px;
		overflow: hidden;
		margin-bottom: 2rem;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
	}

	.cover-image {
		width: 100%;
		height: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.content-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		flex-grow: 1;
	}

	.title-header {
		display: flex;
		gap: 1rem;
	}

	.album-title {
		font-family: var(--font-family-main);
		font-size: var(--text-xl);
		color: var(--heading-color);
		margin: 0;
	}

	.album-year {
		font-family: var(--font-family-secondary);
		font-size: var(--text-lg);
		color: var(--text-color-muted);
		font-style: italic;
	}

	.track-list {
		list-style: none;
		counter-reset: track-counter;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0;
		margin: 0;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: thin;
	}

	.track-list::-webkit-scrollbar {
		width: 4px;
	}

	.track-list::-webkit-scrollbar-track {
		background: transparent;
	}

	.track-list::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.2);
		border-radius: 4px;
	}

	.track-item {
		counter-increment: track-counter;
		font-family: var(--font-family-secondary);
		font-size: var(--text-base);
		color: var(--text-color);
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		transition:
			color 0.2s ease,
			transform 0.2s ease,
			opacity 0.2s ease;
	}

	.track-item::before {
		content: counter(track-counter) ".";
		font-style: italic;
		color: var(--text-color-muted);
		width: 1.5rem;
		flex-shrink: 0;
	}

	.album-card:not(.active) .track-item:hover {
		color: var(--heading-color);
		transform: translateX(4px);
	}


	.iframe-container {
		width: 100%;
		flex-grow: 1;
		min-height: 200px; /* Ensures the iframe has room when back face has no intrinsic height */
		border-radius: 12px;
		overflow: hidden;
	}

	/* Loader & Spinner */
	.loader-container {
		position: absolute;
		top: 3.5rem;
		left: 2rem;
		right: 2rem;
		bottom: 2rem;
		display: flex;
		justify-content: center;
		align-items: center;
		background: rgba(20, 20, 20, 0.4);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-radius: 12px;
		z-index: 4;
		transition: opacity 0.3s ease;
	}

	.spinner {
		width: 36px;
		height: 36px;
		border: 3px solid rgba(255, 255, 255, 0.1);
		border-top-color: #ff5500; /* SoundCloud Orange */
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}
</style>

<script>
	function setupAlbumCards(): void {
		document
			.querySelectorAll<HTMLElement>(".album-card")
			.forEach((card) => {
				// Skip if already initialized
				if (card.dataset.initialized === "true") return;
				card.dataset.initialized = "true";

				const closeBtn =
					card.querySelector<HTMLButtonElement>('.close-btn');
				const iframeContainer =
					card.querySelector<HTMLElement>(".iframe-container");
				const soundcloudUrl = card.dataset.soundcloudUrl;

				// Bug 2 fix: track the cleanup timer so it can be cancelled on re-open
				let cleanupTimer: ReturnType<typeof setTimeout> | null = null;

				// Flip card open and inject iframe
				card.addEventListener("click", (e: MouseEvent) => {
					const target = e.target as HTMLElement;
					if (
						card.classList.contains("active") ||
						target.closest(".close-player-btn")
					) {
						return;
					}

					// Cancel any pending cleanup from a previous close
					if (cleanupTimer !== null) {
						clearTimeout(cleanupTimer);
						cleanupTimer = null;
					}

					card.classList.add("active");

					// Only inject if container is empty (guard against duplicates)
					if (
						soundcloudUrl &&
						iframeContainer &&
						!iframeContainer.querySelector("iframe")
					) {
						const baseUrl = "https://w.soundcloud.com/player/";
						const params = [
							`url=${encodeURIComponent(soundcloudUrl)}`,
							"color=%23ff5500",
							"auto_play=false",
							"hide_related=true",
							"show_comments=false",
							"show_user=false",
							"show_reposts=false",
							"show_teaser=false",
							"visual=false"
						].join("&");
						const embedUrl = `${baseUrl}?${params}`;

						const iframe = document.createElement("iframe");
						iframe.src = embedUrl;
						iframe.width = "100%";
						iframe.height = "100%";
						iframe.setAttribute("scrolling", "no");
						iframe.setAttribute("frameborder", "no");
						iframe.allow = "autoplay";
						iframe.style.border = "none";
						iframeContainer.appendChild(iframe);
					}
				});

				// Flip card closed and schedule iframe cleanup
				closeBtn?.addEventListener("click", (e: MouseEvent) => {
					e.stopPropagation();
					card.classList.remove("active");

					// Clear iframe after flip-back animation completes (0.8s)
					cleanupTimer = setTimeout(() => {
						if (iframeContainer) iframeContainer.innerHTML = "";
						cleanupTimer = null;
					}, 800);
				});
			});
	}

	// Initialize on page load
	setupAlbumCards();

	// Support view transition navigation (Astro swaps content on transitions)
	document.addEventListener("astro:after-swap", setupAlbumCards);
</script>
