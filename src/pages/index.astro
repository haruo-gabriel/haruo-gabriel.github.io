---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="haruo g.">
	<section class="nav-section">
		<nav>
			<ul class="nav-list">
				<li><a href="/bio">bio</a></li>
				<li><a href="/cv">cv</a></li>
				<li><a href="/softwares">softwares</a></li>
				<li><a href="/hardwares">hardwares</a></li>
				<li><a href="/musicas">músicas</a></li>
				<li><a href="/imagens">imagens</a></li>
				<li><a href="/videos">vídeos</a></li>
				<li><a href="/tcc">tcc</a></li>
			</ul>
		</nav>
	</section>

	<section class="quote-section">
		<p class="lacan-quote">
			"O amor é dar algo que você não tem para alguém que não quer."
			<br />
			<span>- Jacques Lacan</span>
		</p>
	</section>
</BaseLayout>

<style>
	/* index.css - Specific styles for the homepage */

	.quote-section {
		/* scroll-snap-align: start; */
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
	}

	.lacan-quote {
		font-family: var(--font-family-main);
		font-size: var(--text-base);
		color: var(--text-color);
	}

	.lacan-quote span {
		display: block;
		margin-top: 1.5rem;
		font-size: var(--text-base);
		color: var(--text-color-muted);
	}
</style>
