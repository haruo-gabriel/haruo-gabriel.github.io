---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="bio - haruo g.">
	<section class="formal-content">
		<div class="my-portrait">
			<img src="/assets/eu.jpg" alt="Haruo" class="portrait-img" />
		</div>
		<div>
			<p>Gabriel Haruo. Baseado em São Paulo, SP - Brasil.</p>
			<p>
				Graduando em Ciência da Computação pelo IME-USP. Pesquisador em
				Computação Aplicada à Música. Desenvolvedor de sistemas Web &
				Desktop. Cheque meu CV <a href="/cv">aqui</a>.
			</p>
			<p>
				Maker de equipamentos eletrônicos sonoros. Crio, construo e
				vendo sintetizadores e pedais de guitarra digitais pela marca <a
					href="https://instagram.com/menis______"
					target="_blank"
					rel="noopener noreferrer">Menis</a
				>.
			</p>
			<p>
				Paralelamente, sou músico & produtor musical & engenheiro de som
				& designer gráfico & <i>etc, etc, etc</i> independente.
			</p>
		</div>
	</section>

	<section class="informal-content">
		<p>gosto de restaurantes pequenos e aconchegantes.</p>
		<p>não gosto de dias nublados.</p>
	</section>

	<script>
		// Setup Image Zoom functionality on page load
		document.addEventListener("astro:page-load", () => {
			const portraitImg =
				document.querySelector<HTMLElement>(".portrait-img");
			if (portraitImg) {
				portraitImg.addEventListener("click", () => {
					const isZoomed = portraitImg.classList.toggle("zoomed");

					if (isZoomed) {
						// Calculate distance to center of viewport
						const rect = portraitImg.getBoundingClientRect();
						const viewportCenterX = window.innerWidth / 2;
						const viewportCenterY = window.innerHeight / 2;
						const imageCenterX = rect.left + rect.width / 2;
						const imageCenterY = rect.top + rect.height / 2;

						const translateX = viewportCenterX - imageCenterX;
						const translateY = viewportCenterY - imageCenterY;

						// Calculate max scale to fit within 90% of viewport
						const scaleX = (window.innerWidth * 0.9) / rect.width;
						const scaleY = (window.innerHeight * 0.9) / rect.height;
						const scale = Math.min(scaleX, scaleY, 4.5); // cap at 4.5x scale

						// Apply dynamic transform
						portraitImg.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
					} else {
						// Reset to default
						portraitImg.style.transform = "";
					}
				});
			}
		});
	</script>
</BaseLayout>

<style>
	/* bio.css - Specific styles for the bio page */

	/* FORMAL CONTENT */

	.formal-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: left;
		min-height: 100vh;
		margin-top: 4rem;
	}

	.formal-content p {
		font-family: var(--font-family-secondary);
		font-size: var(--font-size-secondary);
	}

	/* PORTRAIT PICTURE */

	.my-portrait {
		display: flex;
		justify-content: center;
		margin-bottom: 50px;
	}

	.portrait-img {
		width: 175px;
		aspect-ratio: 1 / 1.1;
		object-fit: cover;
		object-position: center 100%;
		border: 12px solid #d3d3d3;
		transform: rotate(-0.8deg);
		transition: transform 0.3s ease;
	}

	.portrait-img:hover {
		transform: rotate(0deg) scale(1.05);
		cursor: zoom-in;
	}

	.portrait-img.zoomed {
		z-index: 1000;
		box-shadow: 0 0 0 100vmax rgba(0, 0, 0, 0.8);
		cursor: zoom-out;
	}

	/* Ensure the parent doesn't clip the zoomed image or backdrop */
	.formal-content,
	.main-content {
		overflow: visible !important;
	}

	/* INFORMAL CONTENT */

	.informal-content {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	.informal-content p,
	li {
		font-family: var(--font-family-main);
		font-size: var(--text-base);
	}
</style>
