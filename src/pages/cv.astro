---
import ArticleLayout from "../layouts/ArticleLayout.astro";
import ArticleHeader from "../components/ArticleHeader.astro";
import cvPdf from "../assets/cv-ptbr.pdf";
---

<ArticleLayout title="cv - haruo g.">
	<ArticleHeader title="Curriculum Vitae">
		<p>Veja o meu currículo (em português brasileiro) abaixo.</p>
	</ArticleHeader>
	<section>
		<div class="cv-container">
			<iframe
				src={cvPdf}
				title="Curriculum Vitae Preview"
				class="cv-iframe"
			>
			</iframe>
		</div>
	</section>
</ArticleLayout>

<style>
	.cv-container {
		margin-top: 2rem;
		width: 100%;
		/* A4 Aspect Ratio: 1 / 1.414 */
		aspect-ratio: 1 / 1.414;
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.cv-iframe {
		width: 100%;
		height: 100%;
		border: none;
		display: block;
	}

	@media (max-width: 768px) {
		.cv-container {
			aspect-ratio: auto;
			height: 80vh;
		}
	}
</style>
