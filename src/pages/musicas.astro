---
import ArticlesLayout from "../layouts/ArticlesLayout.astro";
import Article from "../components/Article.astro";
import AlbumCard from "../components/AlbumCard.astro";
import { albums } from "../data/albums";
---

<ArticlesLayout title="músicas - haruo g.">
	<Article title="músicas" level={1}>
		<p>
			Dê uma ouvida nos projetos solo que lancei. Nenhum desses álbuns
			está completo, já que produzo só de vez em quando. Mas ainda estão
			em andamento, vivos, e sem prazo pra serem finalizados.
		</p>
		<p>
			Quer ver outros singles? Acessa meu SoundCloud no ícone aí embaixo
			da página.
		</p>
		<div class="albums-grid">
			{albums.map((album) => <AlbumCard {...album} />)}
		</div>
	</Article>
</ArticlesLayout>

<style>
	.albums-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		width: 100%;
	}

	@media (max-width: 768px) {
		.albums-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
